{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CoachingMetricsResponse",
  "title": "CoachingMetricsResponse",
  "type": "object",
  "properties": {
    "requestId": {
      "type": "string",
      "description": "A unique identifier for the request."
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "The user ID."
          },
          "callsListenedTo": {
            "type": "integer",
            "description": "Number of direct report calls listened to."
          },
          "commentsGiven": {
            "type": "integer",
            "description": "Number of comments given to direct reports."
          },
          "scorecardsFilled": {
            "type": "integer",
            "description": "Number of scorecards filled for direct reports."
          }
        }
      },
      "description": "Coaching metrics data."
    }
  }
}