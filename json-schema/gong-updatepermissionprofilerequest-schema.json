{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UpdatePermissionProfileRequest",
  "title": "UpdatePermissionProfileRequest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Updated name for the permission profile."
    },
    "description": {
      "type": "string",
      "description": "Updated description."
    },
    "permissions": {
      "type": "object",
      "properties": {
        "viewOwnCalls": {
          "type": "boolean"
        },
        "viewTeamCalls": {
          "type": "boolean"
        },
        "viewAllCalls": {
          "type": "boolean"
        },
        "downloadRecordings": {
          "type": "boolean"
        },
        "shareExternally": {
          "type": "boolean"
        },
        "createScorecards": {
          "type": "boolean"
        },
        "manageUsers": {
          "type": "boolean"
        },
        "manageSettings": {
          "type": "boolean"
        }
      },
      "description": "Updated permission flags."
    }
  }
}