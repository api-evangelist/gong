              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "folderId",
                  "description": "(Required) The unique identifier of the library folder."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
